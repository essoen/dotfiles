#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

OPTIONAL_SCRIPTS=(brew ente keyd proton vscode 1password-cli kopia rclone b2 ollama waydroid dnf-automatic kde-restore dotfiles)

if ! command -v gum &> /dev/null; then
  sudo dnf install -y gum
fi

echo "Select optional scripts to run after setup (space to toggle, enter to confirm):"
mapfile -t SELECTED < <(gum choose --no-limit "${OPTIONAL_SCRIPTS[@]}")
echo ""

# --- 1. SYSTEM UPDATE & RPM FUSION ---
sudo dnf upgrade -y

# Enable RPM Fusion (Essential for Steam, NVidia/AMD drivers, and codecs)
if ! dnf repolist | grep -q rpmfusion-free; then
  sudo dnf install -y \
    https://download1.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm \
    https://download1.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm
fi

# --- 2. FLATPAK SETUP ---
# Enable Flathub (must be before any flatpak installs)
sudo flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo

# --- 3. GAMING STACK & HARDWARE DRIVERS ---

# Install AMD 32-bit libs for Proton, plus launchers and tools
sudo dnf install -y \
  vulkan-loader.i686 mesa-vulkan-drivers.i686 mesa-libGL.i686 \
  lutris gamemode mangohud

# Steam: RPM version (Flatpak version has compatibility issues)
sudo dnf install -y steam

# Bottles: Windows app compatibility layer
flatpak install -y flathub com.usebottles.bottles

# Proton VPN: Add repo and install (graceful if repo lacks current Fedora version)
{
  if ! dnf repolist | grep -q protonvpn; then
    sudo dnf install -y https://repo.protonvpn.com/fedora-$(rpm -E %fedora)-stable/protonvpn-stable-release/protonvpn-stable-release-1.0.3-1.noarch.rpm
  fi
  sudo dnf install -y proton-vpn-gtk-app proton-mail
} || echo "  ⚠ Proton VPN install failed (repo may not support Fedora $(rpm -E %fedora) yet) — skipping"

# Solaar for Logitech MX Keys/Master
sudo dnf install -y solaar

# Snapshot tools
sudo dnf install -y snapper btrfs-assistant

# OpenRazer for DeathAdder
# Adds the OpenSUSE build repo for Fedora (graceful: OBS lags behind Fedora releases)
{
  FEDORA_VER=$(rpm -E %fedora)
  RAZER_REPO_URL="https://download.opensuse.org/repositories/hardware:razer/Fedora_${FEDORA_VER}/hardware:razer.repo"
  if curl -sfL "$RAZER_REPO_URL" | grep -q "\[hardware_razer\]"; then
    if ! dnf repolist | grep -q hardware_razer; then
      sudo dnf config-manager --add-repo "$RAZER_REPO_URL"
    fi
    sudo dnf install -y openrazer-meta openrazer-driver-dkms
    sudo usermod -aG plugdev $USER
  else
    echo "  ⚠ OpenRazer repo not yet available for Fedora ${FEDORA_VER} — skipping"
  fi
} || echo "  ⚠ OpenRazer install failed — skipping"

# --- 4. PRODUCTIVITY APPS ---
# Discord: Official build wrapped in Flatpak
flatpak install -y flathub com.discordapp.Discord

# Slack: Official client
flatpak install -y flathub com.slack.Slack

# Obsidian: Verified by devs
flatpak install -y flathub md.obsidian.Obsidian

# Todoist: Task management
flatpak install -y flathub com.todoist.Todoist

# Calibre: E-book management
flatpak install -y flathub com.calibre_ebook.calibre

# Signal: Encrypted messaging
flatpak install -y flathub org.signal.Signal

# Telegram: Messaging
flatpak install -y flathub org.telegram.desktop

# Brave: Web browser
flatpak install -y flathub com.brave.Browser

# QBZ: Hi-fi Qobuz player (RPM, Flatpak has network issues)
{
  QBZ_RPM=$(curl -s https://api.github.com/repos/vicrodh/qbz/releases/latest | grep -oE 'https://[^"]*x86_64\.rpm' | head -1)
  if [[ -n "$QBZ_RPM" ]]; then
    sudo dnf install -y "$QBZ_RPM"
  else
    echo "  ⚠ QBZ: could not resolve latest RPM URL — skipping"
  fi
} || echo "  ⚠ QBZ install failed — skipping"

# 1Password: Password manager
flatpak install -y flathub com.onepassword.OnePassword

# Handy: Window management (latest RPM from GitHub)
{
  sudo dnf install -y gtk-layer-shell
  HANDY_RPM=$(curl -s https://api.github.com/repos/cjpais/Handy/releases/latest | grep -oE 'https://[^"]*x86_64\.rpm' | head -1)
  if [[ -n "$HANDY_RPM" ]]; then
    sudo dnf install -y "$HANDY_RPM"
  else
    echo "  ⚠ Handy: could not resolve latest RPM URL — skipping"
  fi
} || echo "  ⚠ Handy install failed — skipping"

# vim
sudo dnf install -y vim

# homebrew pre-req
sudo dnf group install -y development-tools

# claude
if ! command -v claude &> /dev/null; then
  curl -fsSL https://claude.ai/install.sh | bash
fi

# --- RUN SELECTED OPTIONAL SCRIPTS ---
REPO_DIR="$(dirname "$SCRIPT_DIR")"
for script in "${SELECTED[@]}"; do
  echo "Running $script..."
  case "$script" in
    kde-restore) bash "$REPO_DIR/kde/kde-panel" restore ;;
    dotfiles)    bash "$REPO_DIR/setup" ;;
    *)           bash "$SCRIPT_DIR/$script" ;;
  esac
done
