#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "Installing gamescope..."
sudo dnf install -y gamescope

echo "Symlinking Steam (Big Picture, 1080p) launcher..."
mkdir -p "$HOME/.local/share/applications"
ln -sf "$SCRIPT_DIR/files/steam-bigpicture-gamescope.desktop" \
       "$HOME/.local/share/applications/steam-bigpicture-gamescope.desktop"

# Refresh KDE's app cache so the new entry shows up immediately
command -v kbuildsycoca6 &> /dev/null && kbuildsycoca6 --noincremental || true

echo "Done. Look for 'Steam (Big Picture, 1080p)' in your app launcher."
